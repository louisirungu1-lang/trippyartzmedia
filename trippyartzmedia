<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Trippy Artz Media</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<header>
<div class="logo">Trippy Artz Media</div>
<nav>
<a href="#services">Services</a>
<a href="#portfolio">Portfolio</a>
<a href="#pricing">Pricing</a>
<a href="#contact">Contact</a>
</nav>
</header>

<section class="hero">
<h1>Capturing Moments. Creating Art.</h1>
<p>Photography | Videography | Livestream</p>
<a href="#contact" class="btn">Book a Shoot</a>
</section>

<section id="services">
<h2>Our Services</h2>
<div class="service-boxes">
<div class="service">Photography</div>
<div class="service">Videography</div>
<div class="service">Livestream</div>
</div>
</section>

<section id="portfolio">
<h2>Portfolio</h2>
<div class="gallery">
<!-- Add your images here -->
<img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7">
<img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee">
<img src="https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e">
</div>
</section>

<section id="pricing">
<h2>Packages</h2>
<div class="packages">
<div class="package">
<h3>Basic</h3><p>2 hours coverage, 100 photos</p><p>KES 8,000</p>
</div>
<div class="package">
<h3>Standard</h3><p>6 hours, 300 photos + video</p><p>KES 20,000</p>
</div>
<div class="package">
<h3>Premium</h3><p>Full day, cinematic video + drone</p><p>KES 45,000</p>
</div>
</div>
</section>

<section id="contact">
<h2>Book a Shoot</h2>
<form>
<input type="text" placeholder="Name" required>
<input type="email" placeholder="Email" required>
<input type="text" placeholder="Phone" required>
<textarea placeholder="Event Details"></textarea>
<button type="submit">Send Booking</button>
</form>
<p>Or pay via M-Pesa: *123*1#</p>
</section>

<footer>
<p>© 2026 Trippy Artz Media | Nairobi Kenya</p>
</footer>

<script src="script.js"></script>
</body>
</html>
body{margin:0;font-family:Arial;color:#fff;background:#111}
header{display:flex;justify-content:space-between;padding:20px 10%;background:black}
.logo{color:#00f7ff;font-size:24px;font-weight:bold}
nav a{color:white;margin-left:20px;text-decoration:none}
.hero{height:90vh;background:url('https://images.unsplash.com/photo-1516035069371-29a1b244cc32') center/cover;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}
.hero h1{font-size:50px}
.hero p{font-size:20px;margin-top:10px}
.btn{margin-top:20px;padding:15px 30px;background:#00f7ff;color:black;text-decoration:none;border-radius:5px}
section{padding:80px 10%;text-align:center}
.service-boxes{display:flex;justify-content:center;gap:30px;flex-wrap:wrap}
.service{background:#1c1c1c;padding:20px;border-radius:10px;width:250px}
.gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:15px;margin-top:30px}
.gallery img{width:100%;border-radius:8px}
.packages{display:flex;justify-content:center;gap:30px;flex-wrap:wrap;margin-top:30px}
.package{background:#1c1c1c;padding:20px;border-radius:10px;width:250px}
form{display:flex;flex-direction:column;gap:15px;max-width:400px;margin:0 auto}
input,textarea{padding:10px;border-radius:5px;border:none}
button{padding:12px;background:#00f7ff;color:black;border:none;border-radius:5px;cursor:pointer}
footer{background:black;padding:30px;text-align:center;margin-top:40px}
// placeholder for future features (gallery filter, smooth scroll, etc.)
